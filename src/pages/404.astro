---
import BaseLayout from '@layouts/BaseLayout.astro';
import { t } from '@i18n/index';

// The 404 page is static — language is detected client-side via JS below.
// We render with 'it' as the build-time default so SSR/crawlers get valid markup.
const lang = 'it' as const;
const dict = t(lang);
---

<BaseLayout
  lang={lang}
  title={`Pagina non trovata — ${dict.site_title}`}
  description="La pagina che cerchi non esiste o è stata rimossa."
>
  <section class="min-h-[80vh] flex flex-col items-center justify-center px-6 md:px-10 text-center">
    <p
      id="err-eyebrow"
      class="text-[0.65rem] tracking-[0.25em] uppercase text-ink/40 mb-6"
      data-reveal
    >
      Errore 404
    </p>

    <h1
      id="err-title"
      class="font-serif italic font-light text-[clamp(3rem,12vw,9rem)] leading-none tracking-tight text-ink mb-8"
      data-reveal
    >
      Pagina non trovata
    </h1>

    <p
      id="err-body"
      class="font-mono text-sm text-ink/50 max-w-xs mb-12"
      data-reveal
    >
      La pagina che cerchi non esiste o è stata rimossa.
    </p>

    <a
      id="err-cta"
      href="/it"
      class="inline-flex items-center gap-2 font-mono text-[0.65rem] tracking-[0.2em] uppercase border border-ink/20 px-6 py-3 hover:border-ink/60 transition-colors duration-300"
      data-reveal
    >
      Torna alla home
    </a>
  </section>
</BaseLayout>

<script>
  // Detect language from the actual URL the user visited and update copy.
  const isEn = window.location.pathname.startsWith('/en');
  if (isEn) {
    document.getElementById('err-eyebrow')!.textContent = 'Error 404';
    document.getElementById('err-title')!.textContent = 'Page not found';
    document.getElementById('err-body')!.textContent =
      'The page you are looking for does not exist or has been removed.';
    const cta = document.getElementById('err-cta') as HTMLAnchorElement;
    cta.textContent = 'Back to home';
    cta.href = '/en';
  }
</script>
