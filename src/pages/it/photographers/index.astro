---
import BaseLayout from '@layouts/BaseLayout.astro';
import PhotographersListPage from '@components/PhotographersListPage.astro';
import { t } from '@i18n/index';
const dict = t('it');
---
<BaseLayout
  lang="it"
  title={dict.seo.photographers_title}
  description={dict.seo.photographers_desc}
  keywords={['fotografi percezione visiva','fotografia e psicologia','autori mostra fotografica']}
>
  <PhotographersListPage lang="it" />
</BaseLayout>
