---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PhotographerDetailPage from '@components/PhotographerDetailPage.astro';
import { pick } from '@utils/data';

export async function getStaticPaths() {
  const items = await getCollection('photographers');
  return items.map((it) => ({ params: { slug: it.data.slug }, props: { entry: it } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'photographers'> };
const p = entry.data;
const title = `${p.name} — ${pick(p.role, 'it')} · Oltre il Visibile`;
const desc = pick(p.statement, 'it');
---
<BaseLayout
  lang="it"
  title={title}
  description={desc}
  type="article"
  keywords={['fotografo percezione visiva', p.name, 'fotografia e psicologia']}
>
  <PhotographerDetailPage lang="it" slug={p.slug} />
</BaseLayout>
