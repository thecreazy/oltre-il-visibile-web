---
import BaseLayout from '@layouts/BaseLayout.astro';
import ManifestoPage from '@components/ManifestoPage.astro';
import { t } from '@i18n/index';
const dict = t('it');
---
<BaseLayout
  lang="it"
  title={dict.seo.manifesto_title}
  description={dict.seo.manifesto_desc}
  type="article"
  image="/og/manifesto.svg"
  keywords={['manifesto fotografia psicologia','percezione visiva fotografia','mostra fotografica Milano']}
>
  <ManifestoPage lang="it" />
</BaseLayout>
