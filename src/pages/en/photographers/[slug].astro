---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PhotographerDetailPage from '@components/PhotographerDetailPage.astro';
import { pick, pickOpt } from '@utils/data';

export async function getStaticPaths() {
  const items = await getCollection('photographers');
  return items.map((it) => ({ params: { slug: it.data.slug }, props: { entry: it } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'photographers'> };
const p = entry.data;
const title = `${p.name} — ${pick(p.role, 'en')} · Oltre il Visibile`;
const desc = pickOpt(p.statement, 'en');
---
<BaseLayout
  lang="en"
  title={title}
  description={desc}
  type="article"
  keywords={['psychology photographer', p.name, 'visual perception photography']}
>
  <PhotographerDetailPage lang="en" slug={p.slug} />
</BaseLayout>
