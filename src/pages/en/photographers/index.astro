---
import BaseLayout from '@layouts/BaseLayout.astro';
import PhotographersListPage from '@components/PhotographersListPage.astro';
import { t } from '@i18n/index';
const dict = t('en');
---
<BaseLayout
  lang="en"
  title={dict.seo.photographers_title}
  description={dict.seo.photographers_desc}
  image="/og/fotografi.svg"
  keywords={['psychology photography photographers','visual perception photography','contemporary photography exhibition']}
>
  <PhotographersListPage lang="en" />
</BaseLayout>
