---
import BaseLayout from '@layouts/BaseLayout.astro';
import PressPage from '@components/PressPage.astro';
import { t } from '@i18n/index';
const dict = t('en');
---
<BaseLayout
  lang="en"
  title={dict.seo.press_title}
  description={dict.seo.press_desc}
  keywords={['press kit exhibition','press office photography','exhibition press materials']}
>
  <PressPage lang="en" />
</BaseLayout>
