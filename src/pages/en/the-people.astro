---
import BaseLayout from '@layouts/BaseLayout.astro';
import RevealText from '@components/RevealText.astro';
import MagneticButton from '@components/MagneticButton.astro';
import { t, path, pressPath } from '@i18n/index';
const dict = t('en');
---

<BaseLayout
  lang="en"
  title="The People — Oltre il Visibile"
  description="An open project for everyone: 10 portraits for anyone who wants to be photographed at the Rome and Piacenza stops of Oltre il Visibile. No requirements, no casting."
  type="article"
  image="/og/the-people.svg"
  keywords={[
    'the people open portrait',
    'photography exhibition Rome Piacenza',
    'free photo session',
    'Oltre il Visibile participate',
  ]}
>
  <!-- ── HEADER ──────────────────────────────────────────── -->
  <section class="px-6 pb-12 pt-40 md:px-10 md:pt-48">
    <p class="eyebrow text-smoke" data-reveal>Special project · June – July 2026</p>
    <h1 class="mt-8 font-display text-mega font-extralight italic leading-[0.85] tracking-tight">
      <RevealText as="span" class="block" text="The" />
      <RevealText as="span" class="block pl-[10vw]" text="People" />
    </h1>
  </section>


  <!-- ── CORPO ARTICOLO ─────────────────────────────────── -->
  <section class="border-t border-ink/15 px-6 pb-24 md:px-10">
    <div class="grid grid-cols-12 gap-x-6 gap-y-16 pt-20">
      <!-- testo principale -->
      <div class="col-span-12 space-y-10 lg:col-span-8">
        <p class="eyebrow text-smoke" data-reveal>The project</p>
        <p
          class="max-w-[60ch] font-sans text-lg leading-relaxed text-ink/90 md:text-xl"
          data-reveal
        >
          <em class="font-display text-2xl italic not-italic">The People</em> is a project born within
          <em>Oltre il Visibile</em> to open the exhibition to anyone who wants to be part of it — not
          as a spectator, but as a subject.
        </p>
        <p
          class="max-w-[60ch] font-sans text-base leading-relaxed text-smoke md:text-lg"
          data-reveal
        >
          At the <strong class="text-ink">Rome</strong> and <strong class="text-ink"
            >Piacenza</strong
          >
          stops, we will set up a small photography studio open to the public. Men, women, no age, size
          or height limits — no casting, no selection. Just ten photographs, and the pleasure of being
          truly seen.
        </p>

        <div class="border-l-2 border-gold py-1 pl-6" data-reveal>
          <p class="font-display text-2xl font-light italic leading-snug text-ink md:text-3xl">
            "Ten portraits for each of you. Because involving as many people as possible is the very
            heart of the exhibition."
          </p>
        </div>

        <p class="eyebrow mt-16 text-smoke" data-reveal>How it works</p>
        <ul class="max-w-[55ch] space-y-3 pl-5 font-sans text-base text-ink/90 md:text-lg" style="list-style-type: '— ';" data-reveal>
          <li>Sign up by contacting Massimiliano, Valentina or Luca on Instagram (see below).</li>
          <li>Show up at the stop on the given date — no requirements, no mandatory styling.</li>
          <li>We take 10 photographs of you in a small set inside the exhibition venue.</li>
          <li>The images become part of the <em>The People</em> project by Oltre il Visibile.</li>
        </ul>
      </div>

      <!-- sidebar: date + contatti -->
      <aside class="col-span-12 space-y-12 lg:col-span-4">
        <div class="space-y-6 border border-ink/15 p-6">
          <p class="eyebrow text-smoke">Dates & venues</p>

          <div class="space-y-2">
            <p class="font-mono text-xs tracking-widest text-gold">Rome</p>
            <p class="font-display text-xl font-light italic">Aurelia Gallery</p>
            <p class="font-sans text-sm text-smoke">6 – 7 June 2026</p>
          </div>

          <div class="space-y-2">
            <p class="font-mono text-xs tracking-widest text-gold">Piacenza</p>
            <p class="font-display text-xl font-light italic">Palazzo Gotico</p>
            <p class="font-sans text-sm text-smoke">11 – 12 July 2026</p>
          </div>
        </div>

        <div class="space-y-6 border border-ink/15 p-6">
          <p class="eyebrow text-smoke">Join the list</p>
          <p class="font-sans text-sm leading-relaxed text-smoke">
            Contact one of our referents on Instagram to reserve your spot.
          </p>

          <div class="space-y-3">
            <a
              href="https://www.instagram.com/falso_massimiliano?igsh=cTUzYm8zd3FlZHdz"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3"
            >
              <span class="font-mono text-xs text-gold">IG</span>
              <span
                class="alink font-sans text-sm text-ink transition-colors group-hover:text-gold"
              >
                @falso_massimiliano
              </span>
            </a>
            <a
              href="https://www.instagram.com/vpieri28?igsh=NTgyajY4dTVuY2V6"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3"
            >
              <span class="font-mono text-xs text-gold">IG</span>
              <span
                class="alink font-sans text-sm text-ink transition-colors group-hover:text-gold"
              >
                @vpieri28
              </span>
            </a>
            <a
              href="https://www.instagram.com/lukeketzph"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3"
            >
              <span class="font-mono text-xs text-gold">IG</span>
              <span
                class="alink font-sans text-sm text-ink transition-colors group-hover:text-gold"
              >
                @lukeketzph
              </span>
            </a>
          </div>
        </div>

        <img
          src="/the-people/hero.jpg"
          alt="The People — Oltre il Visibile"
          class="w-full"
          loading="lazy"
        />
      </aside>
    </div>
  </section>

  <!-- ── CTA FOOTER ─────────────────────────────────────── -->
  <section class="border-t border-ink/15 px-6 py-32 md:px-10">
    <div class="grid grid-cols-12 items-end gap-x-6">
      <div class="col-span-12 md:col-span-6">
        <p class="eyebrow text-smoke">— The exhibition</p>
        <p
          class="mt-6 max-w-[26ch] font-display text-editorial font-light italic leading-[1.05]"
          data-reveal
        >
          Discover all the stops of Oltre il Visibile.
        </p>
      </div>
      <div class="col-span-12 mt-10 flex flex-wrap gap-4 md:col-span-6 md:mt-0 md:justify-end">
        <MagneticButton href={path('en', 'exhibitions')}>
          {dict.cta.all_exhibitions}
        </MagneticButton>
        <MagneticButton href={pressPath('en')}> Press </MagneticButton>
      </div>
    </div>
  </section>
</BaseLayout>
