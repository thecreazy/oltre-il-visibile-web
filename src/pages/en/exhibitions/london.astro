---
import BaseLayout from '@layouts/BaseLayout.astro';
import ExhibitionDetailPage from '@components/ExhibitionDetailPage.astro';
import { getEntry } from 'astro:content';
import { pick, pickOpt } from '@utils/data';

const ex = (await getEntry('exhibitions', 'london'))!.data;
const title = `${pick(ex.city, 'en')} — ${ex.venue} · Oltre il Visibile`;
const desc = pick(ex.short_text, 'en');
---
<BaseLayout
  lang="en"
  title={title}
  description={desc}
  type="article"
  keywords={['psychology photography London','University of London exhibition','photography exhibition London']}
>
  <ExhibitionDetailPage lang="en" entryId="london" />
</BaseLayout>
