---
import BaseLayout from '@layouts/BaseLayout.astro';
import ExhibitionDetailPage from '@components/ExhibitionDetailPage.astro';
import { getEntry } from 'astro:content';
import { pick } from '@utils/data';

const ex = (await getEntry('exhibitions', 'milan'))!.data;
const title = `${pick(ex.city, 'en')} — ${ex.venue} · Oltre il Visibile`;
const desc = pick(ex.short_text, 'en');
---
<BaseLayout
  lang="en"
  title={title}
  description={desc}
  type="article"
  keywords={['psychology photography Milan','Spazio Maiocchi exhibition','photography exhibition Milan']}
>
  <ExhibitionDetailPage lang="en" entryId="milan" />
</BaseLayout>
