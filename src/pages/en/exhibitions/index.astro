---
import BaseLayout from '@layouts/BaseLayout.astro';
import ExhibitionsListPage from '@components/ExhibitionsListPage.astro';
import { t } from '@i18n/index';
const dict = t('en');
---
<BaseLayout
  lang="en"
  title={dict.seo.exhibitions_title}
