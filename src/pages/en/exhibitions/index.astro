---
import BaseLayout from '@layouts/BaseLayout.astro';
import ExhibitionsListPage from '@components/ExhibitionsListPage.astro';
import { t } from '@i18n/index';
const dict = t('en');
---
<BaseLayout
  lang="en"
  title={dict.seo.exhibitions_title}
  description={dict.seo.exhibitions_desc}
  keywords={['photography psychology exhibition','photography exhibition Milan','photography exhibition Rome','photography exhibition London']}
>
  <ExhibitionsListPage lang="en" />
</BaseLayout>
