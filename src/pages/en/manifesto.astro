---
import BaseLayout from '@layouts/BaseLayout.astro';
import ManifestoPage from '@components/ManifestoPage.astro';
import { t } from '@i18n/index';
const dict = t('en');
---
<BaseLayout
  lang="en"
  title={dict.seo.manifesto_title}
  description={dict.seo.manifesto_desc}
  type="article"
  keywords={['photography psychology manifesto','visual perception photography','photography exhibition manifesto']}
>
  <ManifestoPage lang="en" />
</BaseLayout>
