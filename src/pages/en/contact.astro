---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactPage from '@components/ContactPage.astro';
import { t } from '@i18n/index';
const dict = t('en');
---
<BaseLayout
  lang="en"
  title={dict.seo.contact_title}
  description={dict.seo.contact_desc}
  keywords={['exhibition contact','curation contact','collaborate exhibition']}
>
  <ContactPage lang="en" />
</BaseLayout>
