---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { CONTACT_EMAIL, SOCIALS } from '@utils/data';
import RevealText from '@components/RevealText.astro';
import MagneticButton from '@components/MagneticButton.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.contact.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.contact.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[28ch]" data-reveal>
        {dict.contact.lead}
      </p>
    </div>
  </div>
</section>

<section class="px-6 md:px-10 pb-32">
  <div class="grid grid-cols-12 gap-x-6 gap-y-16 border-t border-ink/15 pt-12">
    <!-- Form -->
    <form class="col-span-12 md:col-span-7 space-y-10" data-contact novalidate>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8">
        <label class="block">
          <span class="eyebrow text-smoke block mb-2">{dict.contact.name}</span>
          <input class="field" type="text" name="name" required autocomplete="name" />
        </label>
        <label class="block">
          <span class="eyebrow text-smoke block mb-2">{dict.contact.email}</span>
          <input class="field" type="email" name="email" required autocomplete="email" />
        </label>
        <label class="block md:col-span-2">
          <span class="eyebrow text-smoke block mb-2">{dict.contact.subject}</span>
          <input class="field" type="text" name="subject" />
        </label>
        <label class="block md:col-span-2">
          <span class="eyebrow text-smoke block mb-2">{dict.contact.message}</span>
          <textarea class="field h-40 resize-none" name="message" required></textarea>
        </label>
      </div>

      <div class="flex items-center justify-between gap-6">
        <p data-contact-feedback role="status" class="hidden font-mono text-[0.7rem] tracking-[0.18em] uppercase text-smoke"></p>
        <MagneticButton type="submit">{dict.contact.send}</MagneticButton>
      </div>
    </form>

    <!-- Direct -->
    <aside class="col-span-12 md:col-span-4 md:col-start-9 space-y-10">
      <div>
        <p class="eyebrow text-smoke">{dict.contact.direct_email}</p>
        <a href={`mailto:${CONTACT_EMAIL}`} class="block mt-4 font-display italic text-3xl alink">{CONTACT_EMAIL}</a>
      </div>
      <div>
        <p class="eyebrow text-smoke">{dict.footer.column_follow}</p>
        <ul class="mt-4 space-y-2 font-display text-2xl">
          {SOCIALS.map(s => <li><a href={s.href} target="_blank" rel="noopener" class="alink">{s.label} ↗</a></li>)}
        </ul>
      </div>
    </aside>
  </div>
</section>

<script is:inline define:vars={{ langCode: lang, mailto: CONTACT_EMAIL }}>
  document.querySelectorAll('form[data-contact]').forEach((form) => {
    if (form.dataset.bound) return;
    form.dataset.bound = 'true';
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fb = form.querySelector('[data-contact-feedback]');
      const data = Object.fromEntries(new FormData(form).entries());
      if (!data.name || !data.email || !data.message) {
        if (fb) {
          fb.textContent = langCode === 'it' ? '— compila i campi richiesti' : '— please fill the required fields';
          fb.classList.remove('hidden');
        }
        return;
      }
      const subject = encodeURIComponent(String(data.subject || (langCode === 'it' ? 'Messaggio dal sito' : 'Website message')));
      const body = encodeURIComponent(`${data.name} <${data.email}>\n\n${data.message}`);
      window.location.href = `mailto:${mailto}?subject=${subject}&body=${body}`;
      if (fb) {
        fb.textContent = langCode === 'it' ? '— grazie. apriamo il tuo client di posta.' : '— thank you. opening your mail client.';
        fb.classList.remove('hidden');
      }
    });
  });
</script>
