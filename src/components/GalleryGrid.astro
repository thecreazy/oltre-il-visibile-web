---
type Orientation = 'v' | 'h' | 's';

interface Props {
  letters?: string[];
  startNo?: number;
  photographerSlug?: string;
  modelSlug?: string;
  orientations?: Orientation[];
  coverSrc?: string;
  hideEmpty?: boolean;
}

const {
  letters = ['Ø', 'I', 'V'],
  photographerSlug = '',
  modelSlug = '',
  orientations,
  coverSrc = '',
  hideEmpty = false,
} = Astro.props;

const count = orientations?.length ?? 4;

const subjectSlug = photographerSlug || modelSlug;
const subjectBase = photographerSlug ? 'photographers' : 'models';

const photos = subjectSlug
  ? Array.from({ length: count }, (_, i) => `/${subjectBase}/${subjectSlug}/${i + 1}.jpg`)
  : Array.from({ length: count }, (_, i) => (i === 0 ? coverSrc : ''));

function ratio(o: Orientation | undefined): string {
  if (o === 'h') return 'aspect-[3/2]';
  if (o === 's') return 'aspect-[1/1]';
  return 'aspect-[2/3]';
}
---

<div class="columns-1 md:columns-2 gap-x-6">
  {photos.filter(src => !hideEmpty || src).map((src, i) => {
    const o = orientations?.[i];
    const label = letters[i % letters.length] ?? '·';
    const tone = i % 2 === 0 ? 'bg-graphite text-paper' : 'bg-bone text-ink';

    return (
      <div class="break-inside-avoid mb-4 md:mb-6">
        {src ? (
          <div class="gallery-img-wrap" data-reveal-delay={(i * 0.1).toString()}>
            <img
              src={src}
              alt=""
              loading="lazy"
              decoding="async"
              data-parallax="0.12"
            />
          </div>
        ) : (
          <div class={`frame ${ratio(o)} ${tone} relative overflow-hidden`}>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-display italic font-extralight text-[min(48vw,28rem)] leading-none opacity-60 select-none">
                {label}
              </span>
            </div>
          </div>
        )}
      </div>
    );
  })}
</div>
