---
/**
 * Image-like frame: uses a CSS-only typographic placeholder that mimics a
 * fine-art print plate. Accepts a label, a number and a parallax depth.
 */
interface Props {
  label?: string;
  caption?: string;
  no?: string;
  depth?: number;     // 0 - 1
  ratio?: string;     // tailwind aspect class, e.g. 'aspect-[3/4]'
  tone?: 'dark' | 'light';
  class?: string;
}
const {
  label = '',
  caption = '',
  no = '',
  depth = 0.18,
  ratio = 'aspect-[3/4]',
  tone = 'dark',
  class: className = '',
} = Astro.props;

const bg = tone === 'dark' ? 'bg-graphite text-paper' : 'bg-bone text-ink';
---
<figure class={`frame group ${ratio} ${bg} relative overflow-hidden ${className}`}>
  <!-- "Image" — a typographic plate that parallaxes -->
  <div class="absolute inset-0 flex items-center justify-center">
    <span
      class="font-display italic font-extralight text-[min(48vw,28rem)] leading-none opacity-60 select-none"
      data-parallax={depth}
    >
      {label}
    </span>
  </div>

  <!-- corner marks -->
  <span class="absolute top-3 left-3 font-mono text-[0.65rem] tracking-[0.28em] uppercase opacity-70">PLATE&nbsp;{no}</span>
  <span class="absolute bottom-3 right-3 font-mono text-[0.65rem] tracking-[0.28em] uppercase opacity-70">SILVER&nbsp;GELATIN</span>

  {caption && (
    <figcaption class="absolute bottom-3 left-3 font-mono text-[0.65rem] tracking-[0.18em] uppercase opacity-80 max-w-[60%]">
      {caption}
    </figcaption>
  )}
</figure>
