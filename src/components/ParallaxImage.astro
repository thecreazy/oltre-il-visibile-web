---
interface Props {
  src?: string;       // real photo path, e.g. /photographers/ermes-mazzali/1.jpg
  label?: string;
  caption?: string;
  no?: string;
  depth?: number;     // 0 - 1
  ratio?: string;     // tailwind aspect class, e.g. 'aspect-[3/4]'
  tone?: 'dark' | 'light';
  class?: string;
}
const {
  src = '',
  label = '',
  caption = '',
  no = '',
  depth = 0.18,
  ratio = 'aspect-[3/4]',
  tone = 'dark',
  class: className = '',
} = Astro.props;

const bg = tone === 'dark' ? 'bg-graphite text-paper' : 'bg-bone text-ink';
---
<figure class={`frame group ${ratio} ${bg} relative overflow-hidden ${className}`}>
  {src ? (
    <!-- Real photo -->
    <img
      src={src}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      data-parallax={depth}
      loading="lazy"
      decoding="async"
    />
  ) : (
    <!-- Typographic placeholder -->
    <div class="absolute inset-0 flex items-center justify-center">
      <span
        class="font-display italic font-extralight text-[min(48vw,28rem)] leading-none opacity-60 select-none"
        data-parallax={depth}
      >
        {label}
      </span>
    </div>
  )}

  {caption && (
    <figcaption class="absolute bottom-3 left-3 font-mono text-[0.65rem] tracking-[0.18em] uppercase opacity-80 max-w-[60%] mix-blend-difference text-paper">
      {caption}
    </figcaption>
  )}
</figure>
