---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { getCollection } from 'astro:content';
import { pick } from '@utils/data';
import RevealText from '@components/RevealText.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);

const allPartners = await getCollection('partners');

type Category = 'photographer' | 'partner' | 'charity' | 'venue';
const categoryOrder: Category[] = ['photographer', 'partner', 'charity', 'venue'];

const categoryLabels: Record<Category, { it: string; en: string }> = {
  photographer: { it: 'Amici del progetto', en: 'Friends of the project' },
  partner:      { it: 'Partner',          en: 'Partners' },
  charity:      { it: 'Partner solidali', en: 'Charity partners' },
  venue:        { it: 'Sedi ospitanti',   en: 'Host venues' },
};

function inCategory(cat: Category) {
  return allPartners
    .filter(p => p.data.category === cat)
    .sort((a, b) => a.data.order - b.data.order);
}
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.partners.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.partners.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[28ch]" data-reveal>
        {dict.partners.lead}
      </p>
    </div>
  </div>
</section>

{categoryOrder.map(cat => {
  const items = inCategory(cat);
  if (items.length === 0) return null;
  return (
    <section class="px-6 md:px-10 pb-20">
      <div class="grid grid-cols-12 gap-x-6 border-t border-ink/15 pt-10 mb-2">
        <p class="col-span-12 md:col-span-3 eyebrow text-gold">{pick(categoryLabels[cat], lang)}</p>
      </div>
      <ul>
        {items.map((entry, i) => {
          const p = entry.data;
          return (
            <li class="border-t border-ink/15 py-10 grid grid-cols-12 gap-x-6 items-center" data-reveal data-reveal-delay={(i * 0.07).toString()}>
              <div class="col-span-12 md:col-span-5">
                {p.logo && (
                  <img src={p.logo} alt={p.name} class="h-12 w-auto object-contain mb-4" loading="lazy" />
                )}
                <p class="font-display italic font-light text-[clamp(2rem,4.5vw,3.5rem)] leading-[0.95]">{p.name}</p>
                <a href={p.href} target="_blank" rel="noopener" class="alink font-mono text-[0.7rem] tracking-[0.22em] uppercase mt-2 inline-block">↗ {cat === 'venue' ? (lang === 'it' ? 'Mappa' : 'Map') : (lang === 'it' ? 'Visita' : 'Visit')}</a>
              </div>
              <div class="col-span-12 md:col-span-3 mt-10 md:mt-0">
                <p class="font-mono text-[0.7rem] tracking-[0.22em] uppercase text-smoke">{pick(p.kind, lang)}</p>
                <p class="font-mono text-[0.7rem] tracking-[0.22em] uppercase text-mist mt-1">{p.city}</p>
              </div>
              <p class="col-span-12 md:col-span-4 text-smoke leading-relaxed mt-6 md:mt-0">{pick(p.note, lang)}</p>
            </li>
          );
        })}
        <li class="border-t border-ink/15" />
      </ul>
    </section>
  );
})}
