---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { PARTNERS, pick } from '@utils/data';
import RevealText from '@components/RevealText.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.partners.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.partners.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[28ch]" data-reveal>
        {dict.partners.lead}
      </p>
    </div>
  </div>
</section>

<section class="px-6 md:px-10 pb-32">
  <ul>
    <li class="border-t border-ink/15"></li>
    {PARTNERS.map((p, i) => (
      <li class="border-b border-ink/15 py-12 grid grid-cols-12 gap-x-6 items-start" data-reveal data-reveal-delay={(i*0.08).toString()}>
        <span class="col-span-2 md:col-span-1"></span>
        <a href={p.href} target="_blank" rel="noopener" class="col-span-10 md:col-span-5 font-display italic font-light text-[clamp(2.5rem,6vw,5rem)] leading-[0.95] alink">
          {p.name}<span class="not-italic font-mono text-base align-top text-smoke ml-3">↗</span>
        </a>
        <div class="col-span-12 md:col-span-3 mt-4 md:mt-0">
          <p class="font-mono text-[0.7rem] tracking-[0.22em] uppercase text-smoke">{pick(p.kind, lang)}</p>
          <p class="font-mono text-[0.7rem] tracking-[0.22em] uppercase text-mist mt-1">{p.city}</p>
        </div>
        <p class="col-span-12 md:col-span-3 text-smoke leading-relaxed mt-4 md:mt-0">{pick(p.note, lang)}</p>
      </li>
    ))}
  </ul>
</section>
