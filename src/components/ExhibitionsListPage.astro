---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { getCollection } from 'astro:content';
import RevealText from '@components/RevealText.astro';
import ExhibitionCard from '@components/ExhibitionCard.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);

const exhibitions = (await getCollection('exhibitions'))
  .map((e) => e.data)
  .sort((a, b) => Number(a.accent_no) - Number(b.accent_no));
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.exhibitions.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.exhibitions.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[24ch]" data-reveal>
        {dict.exhibitions.lead}
      </p>
    </div>
  </div>
</section>

<section class="px-6 md:px-10">
  {exhibitions.map((ex, i) => (
    <ExhibitionCard
      lang={lang}
      slug_it={ex.slug_it}
      slug_en={ex.slug_en}
      city={ex.city}
      country={ex.country}
      venue={ex.venue}
      venue_note={ex.venue_note}
      short_text={ex.short_text}
      dates={ex.dates}
      season={ex.season}
      accent_no={ex.accent_no}
      map_url={ex.map_url}
      index={i}
    />
  ))}
  <div class="border-t border-ink/15 mt-2"></div>
</section>

<section class="px-6 md:px-10 py-32"></section>
