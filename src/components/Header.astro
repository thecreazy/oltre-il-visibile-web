---
import type { Lang } from '@i18n/index';
import { t, path, home, pressPath } from '@i18n/index';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);

const navItems = [
  { label: dict.nav.manifesto, href: path(lang, 'manifesto') },
  { label: dict.nav.exhibitions, href: path(lang, 'exhibitions') },
  { label: dict.nav.photographers, href: path(lang, 'photographers') },
  // { label: dict.nav.models, href: path(lang, 'models') }, // hidden until ready
  { label: dict.nav.partners, href: path(lang, 'partners') },
  { label: dict.nav.press, href: pressPath(lang) },
  { label: dict.nav.staff, href: path(lang, 'staff') },
  { label: dict.nav.contact, href: path(lang, 'contact') },
];
---

<!--
  Logo is a separate fixed element — kept outside the mix-blend-difference header
  so it always renders in full gold regardless of the background behind it.
-->
<a
  href={home(lang)}
  aria-label={dict.a11y.to_home}
  class="fixed top-0 left-0 z-[55] px-6 md:px-10 py-3 flex items-center"
>
  <img src="/logo-client.png" alt="Oltre il Visibile" class="h-14 md:h-16" />
</a>

<!-- Header: mix-blend-difference applies only to nav + controls -->
<header class="fixed top-0 left-0 right-0 z-50 mix-blend-difference text-paper">
  <div class="px-6 md:px-10 py-5 flex items-center justify-end gap-8">
    <nav class="hidden lg:flex items-center gap-8 font-mono text-[0.7rem] tracking-[0.22em] uppercase" aria-label="primary">
      {navItems.map(it => (
        <a href={it.href} class="alink">{it.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-6">
      <LanguageSwitcher lang={lang} class="hidden sm:flex" />
      <button
        type="button"
        data-menu-trigger
        aria-expanded="false"
        aria-controls="primary-menu"
        aria-label={dict.a11y.open_menu}
        class="lg:hidden font-mono text-[0.7rem] tracking-[0.28em] uppercase border border-current px-3 py-2"
      >
        {dict.cta.menu}
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div id="primary-menu" class="menu-overlay" data-menu-overlay aria-hidden="true">
  <div class="px-6 md:px-10 py-4 flex items-center justify-between">
    <a href={home(lang)}>
      <img src="/logo-client.png" alt="Oltre il Visibile" class="h-14" />
    </a>
    <button type="button" data-menu-close aria-label={dict.a11y.close_menu}
      class="font-mono text-[0.7rem] tracking-[0.28em] uppercase border border-current px-3 py-2">
      {dict.cta.close}
    </button>
  </div>

  <nav class="flex-1 px-6 md:px-10 flex flex-col justify-center gap-3 md:gap-5" aria-label="mobile">
    {navItems.map((it, i) => (
      <a href={it.href} class="font-display italic font-light text-[clamp(2.5rem,7vw,5rem)] leading-none tracking-tight">
        <span class="font-mono not-italic text-gold text-[0.7rem] tracking-[0.28em] mr-4 align-middle">0{i+1}</span>
        {it.label}
      </a>
    ))}
  </nav>

  <div class="px-6 md:px-10 py-6 flex items-center justify-between text-paper/70 font-mono text-[0.7rem] tracking-[0.22em] uppercase">
    <LanguageSwitcher lang={lang} class="sm:hidden" />
    <span>2026 — 2027</span>
  </div>
</div>
