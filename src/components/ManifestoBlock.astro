---
interface Props {
  no: string;
  title: string;
  body: string[];
  flip?: boolean;
}
const { no, title, body, flip = false } = Astro.props;
---

<section class={`grid grid-cols-12 gap-x-6 gap-y-6 py-20 md:py-32 border-t border-ink/15 ${flip ? 'md:[direction:rtl]' : ''}`}>
  <div class="col-span-12 md:col-span-1 [direction:ltr]">
    <p class="font-mono text-[0.7rem] tracking-[0.28em] uppercase text-smoke">{no}</p>
  </div>
  <div class="col-span-12 md:col-span-5 [direction:ltr]" data-reveal>
    <h2 class="font-display italic font-light text-editorial leading-[1.02]">{title}</h2>
  </div>
  <div class="col-span-12 md:col-span-5 md:col-start-8 [direction:ltr] space-y-5 max-w-reading">
    {body.map((p, i) => (
      <p class="text-lg md:text-xl leading-relaxed" data-reveal data-reveal-delay={(i*0.1).toString()}>{p}</p>
    ))}
  </div>
</section>
