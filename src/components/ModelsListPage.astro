---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { getCollection } from 'astro:content';
import { existsSync } from 'fs';
import { join } from 'path';
import RevealText from '@components/RevealText.astro';
import ModelCard from '@components/ModelCard.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);

const models = (await getCollection('models'))
  .map((e) => e.data)
  .sort((a, b) => Number(a.accent_no) - Number(b.accent_no));

function coverSrc(slug: string): string {
  const abs = join(process.cwd(), 'public', 'models', slug, '1.jpg');
  return existsSync(abs) ? `/models/${slug}/1.jpg` : '';
}
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.models.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.models.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[28ch]" data-reveal>
        {dict.models.lead}
      </p>
    </div>
  </div>
</section>

<section class="px-6 md:px-10 pb-32">
  <div class="grid grid-cols-12 gap-x-6 gap-y-20">
    {models.map((m, i) => (
      <div class="col-span-12 md:col-span-4">
        <ModelCard
          lang={lang}
          slug={m.slug}
          name={m.name}
          pronouns={m.pronouns}
          based={m.based}
          cover_text={m.cover_text}
          cover_src={coverSrc(m.slug)}
          accent_no={m.accent_no}
          align="left"
        />
      </div>
    ))}
  </div>
</section>
