---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import RevealText from '@components/RevealText.astro';
import PressKitBlock from '@components/PressKitBlock.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.press.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.press.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[28ch]" data-reveal>
        {dict.press.lead}
      </p>
    </div>
  </div>
</section>

<section class="px-6 md:px-10 pb-32">
  <header class="grid grid-cols-12 gap-x-6 gap-y-4 mb-12 border-t border-ink/15 pt-12">
    <p class="col-span-12 md:col-span-3 eyebrow text-smoke">{dict.press.kit_title}</p>
    <p class="col-span-12 md:col-span-9 max-w-[60ch] text-smoke leading-relaxed">{dict.press.kit_text}</p>
  </header>
  <PressKitBlock lang={lang} />
</section>
