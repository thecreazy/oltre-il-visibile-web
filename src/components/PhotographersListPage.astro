---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { getCollection } from 'astro:content';
import RevealText from '@components/RevealText.astro';
import ArtistCard from '@components/ArtistCard.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);

const photographers = (await getCollection('photographers'))
  .map((e) => e.data)
  .sort((a, b) => Number(a.accent_no) - Number(b.accent_no));
---

<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24">
  <div class="grid grid-cols-12 gap-x-6 items-end">
    <div class="col-span-12 md:col-span-7">
      <p class="eyebrow text-smoke" data-reveal>{dict.photographers.eyebrow}</p>
      <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
        <RevealText as="span" class="block" text={dict.photographers.title} />
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:col-start-9 mt-10 md:mt-0">
      <p class="font-display italic text-2xl md:text-3xl text-smoke max-w-[28ch]" data-reveal>
        {dict.photographers.lead}
      </p>
    </div>
  </div>
</section>

<section class="px-6 md:px-10 pb-32">
  <div class="grid grid-cols-12 gap-x-6 gap-y-20">
    {photographers.map((p, i) => (
      <div class={`col-span-12 md:col-span-6 ${i === 1 ? 'md:pl-12' : 'md:pr-12'}`}>
        <ArtistCard
          lang={lang}
          slug={p.slug}
          name={p.name}
          role={p.role}
          based={p.based}
          years={p.years}
          cover_text={p.cover_text}
          accent_no={p.accent_no}
          align={i === 1 ? 'right' : 'left'}
        />
      </div>
    ))}
  </div>
</section>
