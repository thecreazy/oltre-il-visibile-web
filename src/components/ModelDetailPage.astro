---
import type { Lang } from '@i18n/index';
import { t, path } from '@i18n/index';
import { getEntry } from 'astro:content';
import { existsSync } from 'fs';
import { join } from 'path';
import { pick } from '@utils/data';
import RevealText from '@components/RevealText.astro';
import GalleryGrid from '@components/GalleryGrid.astro';
import MagneticButton from '@components/MagneticButton.astro';

interface Props { lang: Lang; slug: string; }
const { lang, slug } = Astro.props;
const dict = t(lang);

const entry = await getEntry('models', slug);
if (!entry) throw new Error(`Model not found: ${slug}`);
const m = entry.data;

function modelPhoto(n: number): string {
  const abs = join(process.cwd(), 'public', 'models', slug, `${n}.jpg`);
  return existsSync(abs) ? `/models/${slug}/${n}.jpg` : '';
}

const coverSrc = modelPhoto(0);
const genres = pick(m.genres, lang);
---

<!-- HERO -->
<section class="relative px-6 md:px-10 pt-40 md:pt-48 pb-24 bg-paper">
  <p class="eyebrow text-smoke" data-reveal>
    {m.based}
  </p>
  <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
    <RevealText as="span" class="block" text={m.name.split(' ')[0]} />
    <RevealText as="span" class="block pl-[10vw]" text={m.name.split(' ').slice(1).join(' ')} />
  </h1>

  <p class="font-display italic text-xl md:text-3xl text-smoke max-w-[44ch]" style="margin-top: 6rem" data-reveal>
    "{pick(m.statement, lang)}"
  </p>
</section>

<!-- GENERI -->
<section class="px-6 md:px-10 py-24 grid grid-cols-12 gap-x-6 gap-y-6 border-t border-ink/15 bg-bone">
  <div class="col-span-12 md:col-span-3">
    <p class="eyebrow text-smoke">{dict.models.genres}</p>
  </div>
  <ul class="col-span-12 md:col-span-9 space-y-0">
    {genres.map((genre, i) => (
      <li
        class="py-5 border-t border-ink/15 flex items-baseline gap-4"
        data-reveal
        data-reveal-delay={(i * 0.07).toString()}
      >
        <span class="font-mono text-[0.6rem] tracking-[0.28em] uppercase text-smoke shrink-0">
          {String(i + 1).padStart(2, '0')}
        </span>
        <span class="font-display italic text-3xl md:text-4xl leading-snug">{genre}</span>
      </li>
    ))}
    <li class="border-t border-ink/15"></li>
  </ul>
</section>

<!-- SOCIALS -->
{m.socials && m.socials.length > 0 && (
  <section class="px-6 md:px-10 py-16 grid grid-cols-12 gap-x-6 gap-y-4 border-t border-ink/15 bg-paper">
    <div class="col-span-12 md:col-span-3">
      <p class="eyebrow text-smoke">Online</p>
    </div>
    <ul class="col-span-12 md:col-span-9 flex flex-wrap gap-x-10 gap-y-3">
      {m.socials.map(s => (
        <li>
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-[0.7rem] tracking-[0.22em] uppercase alink"
          >
            {s.label} ↗
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<!-- GALLERY -->
<section class="px-6 md:px-10 py-24 bg-paper">
  <GalleryGrid
    letters={[m.cover_text, '·', '—']}
    modelSlug={slug}
    coverSrc={coverSrc}
    orientations={m.photo_orientations as ('v'|'h'|'s')[] | undefined}
  />
</section>

<!-- BACK -->
<section class="px-6 md:px-10 py-32 border-t border-ink/15">
  <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
    <a href={path(lang, 'models')} class="alink font-mono text-[0.7rem] tracking-[0.22em] uppercase">← {dict.cta.all_models}</a>
    <MagneticButton href={path(lang, 'exhibitions')}>{dict.cta.all_exhibitions}</MagneticButton>
  </div>
</section>
