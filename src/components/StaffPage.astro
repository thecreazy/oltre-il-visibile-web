---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { STAFF, pick } from '@utils/data';
import RevealText from '@components/RevealText.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);
---

<!-- HERO -->
<section class="px-6 md:px-10 pt-40 md:pt-48 pb-24 bg-paper text-ink">
  <p class="eyebrow text-smoke" data-reveal>{dict.home.staff_eyebrow}</p>
  <h1 class="font-display italic font-extralight text-mega leading-[0.85] tracking-tight mt-8">
    <RevealText as="span" class="block" text={dict.home.staff_title} />
  </h1>
</section>

<!-- STAFF LIST -->
<section class="px-6 md:px-10 py-24 bg-paper">
  <div class="grid grid-cols-12 gap-x-6 gap-y-0">
    {STAFF.map((s, i) => (
      <article
        class="col-span-12 border-t border-ink/15 py-10 grid grid-cols-12 gap-x-6 items-baseline"
        data-reveal
        data-reveal-delay={(i * 0.06).toString()}
      >
        <span class="col-span-12 md:col-span-1 font-mono text-[0.65rem] tracking-[0.28em] uppercase text-mist">
          {String(i + 1).padStart(2, '0')}
        </span>
        <h2 class="col-span-12 md:col-span-3 font-display italic text-3xl mt-2 md:mt-0">
          {s.name}
        </h2>
        <p class="col-span-12 md:col-span-4 font-mono text-[0.7rem] tracking-[0.22em] uppercase text-smoke mt-2 md:mt-0">
          {pick(s.role, lang)}
        </p>
        <p class="col-span-12 md:col-span-3 font-mono text-[0.65rem] tracking-[0.22em] uppercase text-mist mt-1 md:mt-0 md:text-right">
          {s.city}
        </p>
        {s.bio && (
          <p class="col-span-12 md:col-span-8 md:col-start-4 text-smoke leading-relaxed mt-4">
            {pick(s.bio, lang)}
          </p>
        )}
      </article>
    ))}
    <div class="col-span-12 border-t border-ink/15" />
  </div>
</section>
