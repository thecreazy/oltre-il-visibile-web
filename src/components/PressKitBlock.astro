---
import type { Lang } from '@i18n/index';
import { t } from '@i18n/index';
import { PRESS_KIT_BLOCKS, PRESS_CONTACT, pick } from '@utils/data';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const dict = t(lang);
---

<section class="grid grid-cols-12 gap-6">
  {PRESS_KIT_BLOCKS.map((b, i) => (
    <article class="col-span-12 md:col-span-4 border border-ink/15 p-8 flex flex-col" data-reveal data-reveal-delay={(i*0.1).toString()}>
      <span class="font-mono text-[0.65rem] tracking-[0.28em] uppercase text-smoke">N° 0{i+1}</span>
      <h3 class="font-display italic font-light text-3xl mt-3">{pick(b.title, lang)}</h3>
      <p class="text-smoke mt-4 max-w-[34ch] leading-relaxed">{pick(b.body, lang)}</p>
      <div class="mt-auto pt-8 flex items-end justify-between">
        <span class="font-mono text-[0.7rem] tracking-[0.22em] uppercase text-smoke">{b.size}</span>
        <a href={`mailto:${PRESS_CONTACT.email}?subject=${encodeURIComponent('Press kit — ' + pick(b.title, lang))}`} class="alink font-mono text-[0.7rem] tracking-[0.22em] uppercase">
          {dict.press.request} →
        </a>
      </div>
    </article>
  ))}
</section>

<aside class="mt-16 border-t border-ink/15 pt-10 grid grid-cols-12 gap-6">
  <div class="col-span-12 md:col-span-4">
    <p class="eyebrow text-smoke">{dict.press.kit_contact}</p>
  </div>
  <div class="col-span-12 md:col-span-8">
    <p class="font-display italic text-3xl md:text-4xl">{PRESS_CONTACT.name}</p>
    <p class="font-mono text-[0.7rem] tracking-[0.22em] uppercase text-smoke mt-2">{pick(PRESS_CONTACT.role, lang)}</p>
    <a href={`mailto:${PRESS_CONTACT.email}`} class="alink mt-4 inline-block">{PRESS_CONTACT.email}</a>
  </div>
</aside>
